# Hermes backend configuration — copy to backend/.env and fill in.

# --- Core services (match docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://hermes:hermes_pass@localhost:5432/hermes_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                       # only needed for Qdrant Cloud

# --- LLM / embeddings ---
# Ollama server (nomic-embed-text for embeddings, llama3.1:8b / llama3.2:3b for generation).
OLLAMA_API_BASE=http://localhost:11434
# Optional hosted models used by the litellm fallback chain:
# GROQ_API_KEY=
# GEMINI_API_KEY=

# --- Auth ---
# REQUIRED in production. Must be a long random string; startup fails if left
# as the default while ENV=production.
SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
ENV=development

# --- Retrieval tuning ---
# Minimum cross-encoder reranker score for a context to be kept.
MIN_RERANK_SCORE=0.35

# --- Evaluation ---
# Comma-separated allow-list of emails permitted to trigger POST /api/eval/run.
# Leave empty to allow any authenticated user (local/dev convenience).
# EVAL_ADMIN_EMAILS=you@example.com
