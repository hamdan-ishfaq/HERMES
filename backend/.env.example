# Hermes backend configuration — copy to backend/.env and fill in.

# --- Core services (match docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://hermes:hermes_pass@localhost:5432/hermes_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                       # only needed for Qdrant Cloud

# --- LLM / embeddings ---
# Provider: ollama (local GPU) | openrouter (fast/cheap cloud eval)
LLM_PROVIDER=ollama
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_EMBED_TIMEOUT=120
# OpenRouter (set LLM_PROVIDER=openrouter for eval/testing):
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL_SIMPLE=openrouter/meta-llama/llama-3.2-3b-instruct
# OPENROUTER_MODEL_CLASSIFY=openrouter/meta-llama/llama-3.2-3b-instruct
# OPENROUTER_MODEL_COMPLEX=openrouter/google/gemini-2.5-flash-lite
# Optional hosted models used by the litellm fallback chain (ollama mode):
# GROQ_API_KEY=
# GEMINI_API_KEY=

# --- Auth ---
# REQUIRED in production. Must be a long random string; startup fails if left
# as the default while ENV=production.
SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
ENV=development

# --- Retrieval tuning ---
RETRIEVAL_CANDIDATES=50
MIN_RERANK_SCORE=0.25
GRADE_SCORE_THRESHOLD=0.25
HERMES_MULTI_QUERY=1
HERMES_CRAG_LITE=1
HERMES_GRAPH_RAG=0
CONTEXT_PACK_TOP_K=3
CHUNK_STRATEGY=fixed
# EMBED_MODEL=ollama | bge-m3
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_DEVICE=cuda
# Route simple queries to complex model: HERMES_SIMPLE_MODEL=complex

# --- Multi-turn memory (HE-2) ---
HERMES_MULTI_TURN=1
HERMES_MEMORY_TURNS=4

# --- Workspace ACL (HE-4) ---
# Pre-ACL points without user_id are invisible when filtering (re-ingest after upgrade).
# Set to 1 only if you intentionally want legacy public chunks (not recommended).
HERMES_ACL_LEGACY_PUBLIC=0

# --- Tools (HE-7) ---
HERMES_TOOL_LOOP=forced
# Comma-separated host suffixes for optional web_fetch; empty disables.
HERMES_WEB_ALLOWLIST=

# --- Evaluation ---
# Comma-separated allow-list of emails permitted to trigger POST /api/eval/run.
# Leave empty to allow any authenticated user (local/dev convenience).
# EVAL_ADMIN_EMAILS=you@example.com
# Optional judge model override for RAGAS (openrouter/... or ollama model name):
# HERMES_RAGAS_JUDGE=openrouter/google/gemini-2.5-flash-lite